# Long-lived caching for static assets (images + content-hashed JS/CSS).
# Bump an image's filename when its contents change.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icons / manifest
/favicon.ico
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/icon-192.png
  Cache-Control: public, max-age=604800
/icon-512.png
  Cache-Control: public, max-age=604800
